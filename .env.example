# =============================================================================
# Clinic SaaS — environment variables
# =============================================================================
# Copy to .env (or set in Railway/Vercel/your host's env panel).
# The app validates these at boot and refuses to start if anything required
# is missing or malformed (see src/lib/env.ts).

# -----------------------------------------------------------------------------
# Core (REQUIRED)
# -----------------------------------------------------------------------------

# Postgres connection string.
# Railway: copy from your Postgres plugin's "Connect" tab.
# Neon/Supabase: use the pooled connection string for serverless deploys.
DATABASE_URL=postgresql://postgres:iLNNdbzZwjTxmmuAMZscfnzvZDecADpV@trolley.proxy.rlwy.net:37081/railway

# 32+ random bytes, base64 or hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Rotate periodically. iron-session refuses anything shorter than 32 chars.
SESSION_SECRET=replace-me-with-32-plus-random-bytes-base64-encoded

# Public URL where the app is deployed. Used for absolute links in emails,
# OpenGraph tags, sitemaps, etc. No trailing slash.
APP_URL=https://your-clinic-saas.example.com

# 'development' | 'production' | 'test'
NODE_ENV=production

# -----------------------------------------------------------------------------
# File storage (REQUIRED — pick one driver)
# -----------------------------------------------------------------------------

# 'local' for dev (writes to STORAGE_LOCAL_DIR), 's3' for prod.
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# When STORAGE_DRIVER=s3, fill these. Works with any S3-compatible service:
# Cloudflare R2 (recommended — no AWS card required, free tier, free egress),
# Backblaze B2, AWS S3, Supabase Storage, MinIO.
#
# Cloudflare R2 example:
#   STORAGE_DRIVER=s3
#   STORAGE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_S3_REGION=auto
#   STORAGE_S3_BUCKET=your-bucket-name
#   STORAGE_S3_ACCESS_KEY_ID=...
#   STORAGE_S3_SECRET_ACCESS_KEY=...
#   STORAGE_S3_PUBLIC_URL_BASE=https://pub-<hash>.r2.dev   # only if bucket is public
#
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_REGION=auto
# STORAGE_S3_BUCKET=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
# STORAGE_S3_PUBLIC_URL_BASE=

# -----------------------------------------------------------------------------
# Cron (REQUIRED)
# -----------------------------------------------------------------------------

# Shared secret your scheduler sends as `Authorization: Bearer <CRON_SECRET>`
# when hitting /api/cron/*. Min 16 chars.
CRON_SECRET=replace-with-16-plus-random-bytes

# -----------------------------------------------------------------------------
# WhatsApp Cloud API (OPTIONAL — leave blank to disable WhatsApp)
# -----------------------------------------------------------------------------

# META_WHATSAPP_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=
# META_WHATSAPP_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# Google Places (OPTIONAL — for review syncing)
# -----------------------------------------------------------------------------

# GOOGLE_PLACES_API_KEY=

# -----------------------------------------------------------------------------
# Signup gating (OPTIONAL — closed beta)
# -----------------------------------------------------------------------------

# If set, /signup requires a matching `inviteCode`. Leave unset for open signup.
# SIGNUP_INVITE_CODE=

# -----------------------------------------------------------------------------
# Seed / first-deploy convenience (OPTIONAL — only used by `npm run db:seed`)
# -----------------------------------------------------------------------------

# SEED_CLINIC_SLUG=demo
# SEED_CLINIC_NAME=Demo Clinic
# SEED_OWNER_NAME=Demo Owner
# SEED_OWNER_EMAIL=owner@example.com
# SEED_OWNER_PASSWORD=change-me-please-soon
