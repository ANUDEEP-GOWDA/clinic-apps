{
  "name": "clinic-saas",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "echo \"SKIP_ENV_VALIDATION=true\" > .env && echo \"DATABASE_URL=postgresql://dummy:dummy@localhost:5432/dummy\" >> .env && echo \"SESSION_SECRET=this_is_a_dummy_session_secret_for_build_only_12345\" >> .env && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "restore:clinic": "tsx scripts/restore-clinic.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.609.0",
    "@aws-sdk/s3-request-presigner": "^3.609.0",
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "cuid": "^3.0.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "iron-session": "^8.0.3",
    "next": "^14.2.5",
    "otplib": "^12.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
